//Ajedrez 8x8

int filas = 8;
int cols = 8;
int tamaño = 60;

void setup() {
  size(480, 480);
  noStroke();
}

void draw() {
  for (int i = 0; i < filas; i++) {
    for (int j = 0; j < cols; j++) {
      
      if ((i + j) % 2 == 0) {
        fill(255); // blanco
      } else {
        fill(0); // negro
      }
      
      rect(j * tamaño, i * tamaño, tamaño, tamaño);
    }
  }
}
