int filas = 5;
int cols = 8;
int ancho = 60;
int alto = 30;

void setup() {
  size(500, 300);
  background(255);
  
  stroke(255, 105, 180);
  noFill();
  
  for (int i = 0; i < filas; i++) {
    for (int j = 0; j < cols; j++) {
      
      int x = j * ancho;
      int y = i * alto;
      
      // desplazamiento tipo ladrillo
      if (i % 2 == 1) {
        x += ancho / 2;
      }
      
      rect(x, y, ancho, alto);
    }
  }
}
