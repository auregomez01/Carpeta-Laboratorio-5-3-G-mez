
void setup() {
  size(800, 600);
}
void draw(){
  if(estaTocandoelCirculo()) 
    fill(255, 0, 0);
else fill(255);
  
   circle(width/2, height/2, width/2);
}
boolean estaTocandoelCirculo(){
  float r=width/4;
  float d=dist(mouseX, mouseY, width/2, height/2);
  if(d>r)
    return false;
     else return true;
    }
//programa que al pasar el mouse por el círculo se pone en rojo.
